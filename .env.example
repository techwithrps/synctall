# Tally Sync Agent - Environment Configuration Example
# Copy this file to .env and configure actual keys.

# Supabase Configurations
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-secret-key"

# Tally Server Endpoint (usually local port 9000)
TALLY_URL="http://localhost:9000"

# Background Sync Interval (seconds) - Default: 60 seconds
SYNC_INTERVAL_SECONDS=60

# Logging Verbosity level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"
